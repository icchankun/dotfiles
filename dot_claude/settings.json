{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh issue status*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr status*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh repo view*)",
      "Bash(gh repo list*)",
      "Bash(gh release list*)",
      "Bash(gh release view*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh workflow list*)",
      "Bash(gh workflow view*)",
      "Bash(gh search*)",
      "Bash(gh gist list*)",
      "Bash(gh gist view*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git show*)",
      "Bash(bundle list*)",
      "Bash(bundle info*)",
      "Bash(ruby -v*)",
      "Bash(node -v*)",
      "Bash(yarn --version*)",
      "Bash(which *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Read(~/.env)",
      "Read(**/.env)",
      "Read(~/.claude.json)",
      "Read(**/.claude.json)",
      "Bash(cat *.env*)",
      "Bash(env)",
      "Bash(printenv*)"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.bin/rename-cc-session",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "warp@claude-code-warp": true,
    "code-review@claude-plugins-official": true,
    "engineering-skills@claude-code-skills": true,
    "frontend-design@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "language": "Japanese",
  "voiceEnabled": true
}
